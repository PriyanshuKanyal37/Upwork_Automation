{
  "name": "Asana New Task to Slack",
  "flow": [
    {
      "id": 1,
      "module": "asana:WatchNewTasks",
      "version": 2,
      "parameters": {
        "__IMTCONN__": 1,
        "filter": "project",
        "project": "PLACEHOLDER_PROJECT_ID",
        "workspaceRPC": "PLACEHOLDER_WORKSPACE_ID",
        "page": 10
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 0, "y": 0 }
      }
    },
    {
      "id": 2,
      "module": "slack:CreateMessage",
      "version": 4,
      "parameters": {
        "__IMTCONN__": 1
      },
      "mapper": {
        "channel": "C0000000000",
        "channelType": "public",
        "channelWType": "list",
        "text": "New Asana task: {{1.name}}\n{{1.permalink_url}}",
        "mrkdwn": true,
        "parse": false
      },
      "metadata": {
        "designer": { "x": 300, "y": 0 }
      }
    }
  ],
  "metadata": {
    "instant": false,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": { "orphans": [] },
    "zone": "us1.make.com"
  }
}
